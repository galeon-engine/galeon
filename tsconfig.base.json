{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,

    "paths": {
      "@galeon/render-core": ["./packages/render-core/src/index.ts"],
      "@galeon/three": ["./packages/three/src/index.ts"],
      "@galeon/r3f": ["./packages/r3f/src/index.ts"],
      "@galeon/runtime": ["./packages/runtime/src/index.ts"],
      "@galeon/picking": ["./packages/picking/src/index.ts"],
      "@galeon/shell": ["./packages/shell/src/index.ts"]
    },

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
